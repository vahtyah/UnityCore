  m_EditorClassIdentifier: Assembly-CSharp::VahTyah.ModuleNotifications
  _androidChannelId: game_notifications
  _androidChannelName: Game Notifications
  _androidChannelDescription: In-game and re-engagement notifications.
  _androidSmallIconId: 
  _androidIcons: []
  _reEngagement:
  - Id: reengagement_0
    Title: We miss you!
    Body: "Your adventure is waiting \u2014 come back and play!"
    DelayHours: 2
  - Id: reengagement_1
    Title: Don't stop now!
    Body: Big rewards are ready for you. Come claim them!
    DelayHours: 23
  - Id: reengagement_2
    Title: Still there?
    Body: A special bonus is waiting just for you.
    DelayHours: 47
  - Id: reengagement_3
    Title: Your adventure awaits!
    Body: "Three days gone \u2014 your next quest is ready and waiting."
    DelayHours: 71
  - Id: reengagement_4
    Title: Your team needs you!
    Body: Five days away? Jump back in and pick up where you left off!
    DelayHours: 119
  - Id: reengagement_5
    Title: Time to come back!
    Body: "It's been a week \u2014 your rewards are piling up!"
    DelayHours: 167
  - Id: reengagement_6
    Title: We saved your spot!
    Body: "Ten days away \u2014 your adventure is still here waiting for you."
    DelayHours: 239
  - Id: reengagement_7
    Title: One more chance!
    Body: "Two weeks gone \u2014 come back and claim your comeback reward!"
    DelayHours: 335
  - Id: reengagement_8
    Title: We haven't forgotten!
    Body: Three weeks away? A special gift is waiting just for you.
    DelayHours: 503
  - Id: reengagement_9
    Title: Last call!
    Body: "A whole month gone \u2014 your ultimate comeback reward is ready!"
    DelayHours: 671
  _maxScheduled: 10
  _rescheduleCooldownHours: 1
